project Latin_Squares is
   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Main use ("main.adb");

   package Compiler is
      -- Strict compilation switches for high-integrity code
      for Default_Switches ("Ada") use ("-g", "-O2", "-gnata", "-gnatwa");
   end Compiler;

   package Prove is
      -- Run proofs on all files at a standard level
      for Proof_Switches ("Ada") use ("--level=1", "--report=all");
   end Prove;
end Latin_Squares;
